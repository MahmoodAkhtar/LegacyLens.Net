{
  "Application": {
    "Name": "SampleLegacyApp",
    "Mode": "LegacyCompatibility"
  },
  "Api": {
    "BaseUrl": "https://legacy-api.example.local",
    "TimeoutSeconds": 30
  },
  "ConnectionStrings": {
    "MainDatabase": "Server=legacy-sql;Database=SampleLegacyApp;User Id=sample_user;Password=sample-password-do-not-use;",
    "RabbitMQ": "amqp://sample-user:sample-password-do-not-use@rabbitmq-dev:5672/sample"
  },
  "RabbitMQ": {
    "HostName": "rabbitmq-dev",
    "Port": 5672,
    "UserName": "sample-user",
    "Password": "sample-password-do-not-use",
    "VirtualHost": "sample",
    "QueueName": "sample.customer.events",
    "ExchangeName": "sample.customer.exchange"
  },
  "Redis": {
    "Endpoint": "legacy-cache:6379"
  },
  "Smtp": {
    "Host": "smtp.example.local",
    "Port": 25,
    "From": "noreply@example.local",
    "UserName": "sample-smtp-user",
    "Password": "sample-smtp-password-do-not-use"
  },
  "FeatureFlags": {
    "LegacyCheckout": true,
    "UseClassicCustomerSearch": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  }
}