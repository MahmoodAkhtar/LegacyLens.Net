{
  "Application": {
    "Name": "SampleLegacyApp",
    "Mode": "LocalDevelopment"
  },
  "Api": {
    "BaseUrl": "https://localhost:8001",
    "TimeoutSeconds": 30
  },
  "ConnectionStrings": {
    "MainDatabase": "Server=(localdb)\\MSSQLLocalDB;Database=SampleLegacyApp_Dev;Integrated Security=True;",
    "RabbitMQ": "amqp://guest:guest@localhost:5672/"
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "QueueName": "sample.customer.events.dev",
    "ExchangeName": "sample.customer.exchange.dev"
  },
  "Redis": {
    "Endpoint": "localhost:6379"
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 2525,
    "From": "dev-noreply@example.local",
    "UserName": "",
    "Password": ""
  },
  "FeatureFlags": {
    "LegacyCheckout": true,
    "UseClassicCustomerSearch": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "System": "Information"
    }
  }
}